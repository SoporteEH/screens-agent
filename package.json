{
  "name": "local-agent",
  "version": "1.1.46",
  "private": true,
  "description": "ScreensWeb Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron . --js-flags=\"--expose-gc\"",
    "inject:b": "set AGENT_THEME=B&& node scripts/inject-config.js",
    "inject:default": "set AGENT_THEME=default&& node scripts/inject-config.js",
    "start:b": "pnpm inject:b && pnpm start",
    "start:default": "pnpm inject:default && pnpm start",
    "build": "electron-builder",
    "build:prod": "node scripts/inject-config.js && electron-builder",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "SoporteEH",
  "license": "ISC",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.6.0",
    "dotenv": "^17.2.3",
    "electron-log": "^5.1.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.1",
    "form-data": "^4.0.5",
    "jwt-decode": "^4.0.0",
    "node-machine-id": "^1.1.12",
    "socket.io-client": "^4.8.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1"
  },
  "build": {
    "appId": "com.screens.web.agent",
    "productName": "ScreensWeb Agent",
    "copyright": "Copyright © 2026 SoporteEH",
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "config/**/*",
      "services/**/*",
      "handlers/**/*",
      "utils/**/*",
      "icons/**/*",
      "css/**/*",
      "*.html",
      "preload.js",
      "identify-preload.js",
      "package.json",
      "!mainOld.js"
    ],
    "executableName": "screens-web-agent",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis-web",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico",
      "artifactName": "ScreensWebAgent-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "differentialPackage": true,
      "deleteAppDataOnUninstall": true,
      "include": "installer-script.nsh"
    },
    "nsisWeb": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "ScreensWebAgent-installer.${ext}",
      "appPackageUrl": "https://github.com/SoporteEH/ScreensWeb-agent/releases/latest/download/",
      "menuCategory": false
    },
    "linux": {
      "executableName": "screens-web-agent",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "armv7l",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "armv7l",
            "arm64"
          ]
        }
      ],
      "category": "Utility",
      "maintainer": "SoporteEH <soporte@screensweb.com>",
      "synopsis": "ScreensWeb Agent for Digital Signage",
      "description": "Cross-platform agent for ScreensWeb digital signage platform, optimized for Raspberry Pi and Windows."
    },
    "publish": {
      "provider": "github",
      "owner": "SoporteEH",
      "repo": "ScreensWeb-agent"
    }
  },
  "config": {
    "serverUrl": ""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  }
}
